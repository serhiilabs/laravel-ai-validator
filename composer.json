{
    "name": "serhiilabs/laravel-ai-validator",
    "description": "AI-powered validation rules for Laravel using natural language descriptions",
    "keywords": [
        "laravel",
        "validation",
        "ai",
        "llm",
        "openai",
        "anthropic",
        "claude",
        "gemini",
        "prism"
    ],
    "homepage": "https://github.com/serhiilabs/laravel-ai-validator",
    "type": "library",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/serhiilabs/laravel-ai-validator/issues",
        "source": "https://github.com/serhiilabs/laravel-ai-validator"
    },
    "authors": [
        {
            "name": "Serhii Bondarenko",
            "email": "serhiilabs@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/cache": "^11.0 || ^12.0",
        "illuminate/contracts": "^11.0 || ^12.0",
        "illuminate/support": "^11.0 || ^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-arch": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "prism-php/prism": "^0.99 || ^0.100"
    },
    "suggest": {
        "prism-php/prism": "Required for PrismDriver (supports OpenAI, Anthropic, Gemini, Ollama, and 12+ providers)"
    },
    "autoload": {
        "psr-4": {
            "SerhiiLabs\\AiValidator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SerhiiLabs\\AiValidator\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-parallel": "vendor/bin/pest --parallel",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint",
        "lint": "vendor/bin/pint --test",
        "check": ["@lint", "@analyse", "@test-parallel"]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SerhiiLabs\\AiValidator\\AiValidatorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
